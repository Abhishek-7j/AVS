# Copy to .env and load before run, or set in system environment.
# Windows PowerShell:  $env:AVS_USER="admin"; $env:AVS_PASSWORD="your_secret"
# Linux/macOS:         export AVS_PASSWORD="your_secret"

AVS_USER=admin
AVS_PASSWORD=change_me_strong_password

# Set to 1 to open the GUI without the login window (kiosk / lab only).
# AVS_SKIP_LOGIN=0
